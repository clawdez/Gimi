{
  "name": "gimi",
  "version": "0.1.0",
  "private": true,
  "description": "AI rental agent for community inventory with Card or Solana checkout, escrow-backed returns, and on-chain receipts.",
  "homepage": "https://github.com/clawdez/Gimi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawdez/Gimi.git"
  },
  "keywords": [
    "gimi",
    "ai-agent",
    "rentals",
    "community-inventory",
    "solana",
    "privy",
    "moonpay",
    "base",
    "elevenlabs",
    "lifi",
    "mcp"
  ],
  "scripts": {
    "dev": "node scripts/run-next-clean.cjs dev",
    "build": "node scripts/run-next-clean.cjs build",
    "anchor:build": "NO_DNA=1 anchor build",
    "devnet:setup": "node --experimental-strip-types scripts/setup-rentproof-devnet.mjs",
    "demo:seed": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/seed-partner-demo.mjs",
    "e2e:devnet": "node scripts/e2e-owner-listing-rental-devnet.mjs",
    "start": "node scripts/run-next-clean.cjs start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:anchor": "NO_DNA=1 anchor build && cargo test -p rental_session",
    "verify:prod-ready": "npm run typecheck && npm test && npm run lint && npm run build",
    "smoke:moonpay": "node scripts/smoke-moonpay-commerce.mjs"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.24.0",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.9.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/supabase-js": "^2.105.4",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
